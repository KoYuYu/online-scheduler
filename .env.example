DATABASE_URL=postgresql://user:password@host:5432/database
AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-before-production
NOTIFY_TO_EMAIL=jasonko12033@gmail.com
APP_URL=https://your-railway-domain.up.railway.app
CRON_SECRET=replace-with-a-long-random-cron-secret
WEB_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_PRIVATE_KEY=replace-with-vapid-private-key
WEB_PUSH_SUBJECT=mailto:jasonko12033@gmail.com
# Preferred for Railway: HTTPS email delivery, avoids SMTP port restrictions.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Online Scheduler <onboarding@resend.dev>

# SMTP fallback (used only when RESEND_API_KEY is absent).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FORCE_IPV4=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
LOCAL_DATA_PATH=C:/tmp/online-scheduler-local.json
